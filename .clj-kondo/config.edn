{:linters
 {:missing-docstring        {:level   :warning
                             ;; deftest bodies are self-documenting via
                             ;; (testing ...) strings. Docstrings on test
                             ;; vars add noise without epistemic value.
                             :exclude [deftest
                                       clojure.test/deftest]}
  :unused-value             {:level :warning}
  :shadowed-var             {:level :warning}
  :used-underscored-binding {:level :warning}
  :warn-on-reflection       {:level :warning}
  :unsorted-required-namespaces {:level :warning}
  :refer                    {:level   :warning
                              :exclude [clojure.test]}}

 ;; infra.window lives in src/humbleui which is excluded from lint.
 ;; This stanza is belt-and-suspenders if the path ever widens.
 :unresolved-namespace
 {:exclude [io.github.humbleui.window
            io.github.humbleui.ui
            io.github.humbleui.jwm]}

 :lint-as {}}
