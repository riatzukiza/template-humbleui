{:paths ["src/core" "resources"]

 :deps
 {org.clojure/clojure {:mvn/version "1.12.0"}
  metosin/malli       {:mvn/version "0.16.4"}}

 :aliases
 {;; HumbleUI rendering layer — used only by -main and uberjar build.
  ;; Never pulled in by :test or :kondo.
  :humbleui
  {:extra-paths ["src/humbleui"]
   :extra-deps  {io.github.HumbleUI/HumbleUI
                 {:git/url "https://github.com/HumbleUI/HumbleUI.git"
                  :git/sha "ca23454728b347152f019f7bacbb2538cecbfa93"}}}

  :test
  {:extra-paths ["test"]
   :extra-deps  {lambdaisland/kaocha          {:mvn/version "1.91.1392"}
                 lambdaisland/kaocha-junit-xml {:mvn/version "0.0.76"}
                 nubank/matcher-combinators    {:mvn/version "3.9.1"}}
   :main-opts   ["-m" "kaocha.runner"]}

  ;; Lint src/core and test only.
  ;; src/humbleui is excluded: it requires HumbleUI namespaces that kondo
  ;; cannot resolve without the native dep on the classpath.
  :kondo
  {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
   :main-opts  ["-m" "clj-kondo.main" "--lint" "src/core" "test"]}

  :build
  {:deps       {io.github.clojure/tools.build {:git/tag "v0.10.5" :git/sha "2a21b7a"}}
   :ns-default build}}}
